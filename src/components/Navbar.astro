---
const navLinks = [
  { href: "/", label: "Início" },
  { href: "/cronograma", label: "Cronograma" },
  { href: "/palestrantes", label: "Palestrantes" },
  { href: "/hospedagem", label: "Hospedagem" },
  { href: "/inscricoes", label: "Inscrições" },
];

const currentPath = Astro.url.pathname;
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-sm">SRF</span>
        </div>
        <span class="font-semibold text-foreground text-sm hidden sm:block">Simpósio Regional de Física</span>
      </a>

      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors",
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                ? "text-blue-600"
                : "text-foreground/70 hover:text-foreground"
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="hidden md:flex items-center gap-3">
        <a
          href="/inscricoes"
          class="bg-blue-600 text-white text-sm font-medium px-4 py-2 rounded-full hover:bg-blue-700 transition-colors"
        >
          Inscreva-se
        </a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-background border-t border-border">
    <div class="px-4 py-4 space-y-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "block text-sm font-medium py-2",
            currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
              ? "text-blue-600"
              : "text-foreground/70"
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/inscricoes"
        class="block bg-blue-600 text-white text-sm font-medium px-4 py-2 rounded-full text-center hover:bg-blue-700 transition-colors mt-4"
      >
        Inscreva-se
      </a>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById("navbar");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  window.addEventListener("scroll", () => {
    if (navbar) {
      if (window.scrollY > 20) {
        navbar.classList.add("bg-background/80", "backdrop-blur-lg", "shadow-sm");
        navbar.classList.remove("bg-transparent");
      } else {
        navbar.classList.remove("bg-background/80", "backdrop-blur-lg", "shadow-sm");
        navbar.classList.add("bg-transparent");
      }
    }
  });

  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });
</script>
