---
const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${base}/`, label: "Início" },
  { href: `${base}/cronograma`, label: "Cronograma" },
  { href: `${base}/palestrantes`, label: "Palestrantes" },
  { href: `${base}/hospedagem`, label: "Hospedagem" },
  { href: `${base}/inscricoes`, label: "Inscrições" },
];

const currentPath = Astro.url.pathname;
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={`${base}/`} class="flex items-center gap-2">
        <div class="w-8 h-8 bg-black rounded-full flex items-center justify-center">
          <span class="text-white font-bold text-sm italic">SBF</span>
        </div>
        <span class="font-semibold text-foreground text-sm block">V ECF/SBF</span>
      </a>

      <nav class="hidden md:flex items-center gap-3">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors px-3 py-2 rounded-full",
              currentPath === link.href
                ? "text-blue-600 bg-blue-50"
                : "text-foreground/70 hover:text-foreground"
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="hidden md:flex items-center gap-3">
        <a
          href={`${base}/inscricoes`}
          class="bg-blue-600 text-white text-sm font-medium px-4 py-2 rounded-full hover:bg-blue-700 transition-colors"
        >
          Inscreva-se
        </a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 relative w-8 h-8 flex items-center justify-center" aria-label="Menu">
        <svg id="menu-icon-open" class="w-6 h-6 absolute transition-all duration-300 ease-out" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 absolute transition-all duration-300 ease-out rotate-[-90deg] opacity-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0">
    <div class="px-4 py-4 space-y-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "block text-sm font-medium py-2 px-3 rounded-full mb-1",
            currentPath === link.href
              ? "text-blue-600 bg-blue-50"
              : "text-foreground/70"
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href={`${base}/inscricoes`}
        class="block bg-blue-600 text-white text-sm font-medium px-4 py-2 rounded-full text-center hover:bg-blue-700 transition-colors mt-4"
      >
        Inscreva-se
      </a>
    </div>
  </div>
</header>

<style>
  #mobile-menu.open {
    max-height: 400px;
    opacity: 1;
  }
  #menu-icon-close.open {
    opacity: 1;
    rotate: 0deg;
  }
  #menu-icon-open.open {
    opacity: 0;
    rotate: 90deg;
  }
</style>

<script>
  const navbar = document.getElementById("navbar");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIconOpen = document.getElementById("menu-icon-open");
  const menuIconClose = document.getElementById("menu-icon-close");

  window.addEventListener("scroll", () => {
    if (navbar) {
      if (window.scrollY > 20) {
        navbar.classList.add("bg-background/80", "backdrop-blur-lg", "shadow-sm");
        navbar.classList.remove("bg-transparent");
      } else {
        navbar.classList.remove("bg-background/80", "backdrop-blur-lg", "shadow-sm");
        navbar.classList.add("bg-transparent");
      }
    }
  });

  mobileMenuBtn?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.contains("open");
    mobileMenu?.classList.toggle("open");
    menuIconOpen?.classList.toggle("open");
    menuIconClose?.classList.toggle("open");

    if (!isOpen) {
      navbar?.classList.add("bg-background/80", "backdrop-blur-lg", "shadow-sm");
    } else if (window.scrollY <= 20) {
      navbar?.classList.remove("bg-background/80", "backdrop-blur-lg", "shadow-sm");
    }
  });
</script>
