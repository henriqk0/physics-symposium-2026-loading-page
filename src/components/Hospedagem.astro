---
import {
  Building2,
  Building,
  Waves,
  School,
  Coffee,
  WavesLadder,
  Car,
  Wifi,
  Forklift,
  ChefHat,
  PersonStanding,
  Bus,
  WavesIcon,
  Utensils
} from "@lucide/astro";

interface Hotel {
  Icon: typeof Building2;
  name: string;
  dist: string;
  featured: boolean;
  desc: string;
  amenities: { label: string; Icon: typeof Building2 }[];
  price: string;
  priceNote: string;
}

interface Venue {
  locale: string;
  place: string;
  number: string;
  district: string;
  municipality: string;
  state: string;
  identification: string;
  description: string;
  amenities: { label: string; Icon: typeof Building2 }[];
  url: string;
}

const hotels: Hotel[] = [
  {
    Icon: Building2,
    name: "Bristol Vitória Hotel",
    dist: "1,2 km · ~15 min a pé",
    featured: true,
    desc: "Quatro estrelas no coração de Vitória. Tarifas negociadas para participantes mediante código de reserva.",
    amenities: [
      { label: "Café da manhã", Icon: Coffee },
      { label: "Wi-Fi", Icon: Wifi },
      { label: "Estacionamento", Icon: Car },
    ],
    price: "A partir de R$ 220",
    priceNote: "/ noite · código SRF2026",
  },
  {
    Icon: Building,
    name: "Ibis Vitória Centro",
    dist: "800 m · ~10 min a pé",
    featured: false,
    desc: "Opção prática e confortável com excelente custo-benefício, ideal para estudantes e pesquisadores.",
    amenities: [
      { label: "Wi-Fi", Icon: Wifi },
      { label: "Restaurante", Icon: ChefHat },
      { label: "Acessível", Icon: PersonStanding },
    ],
    price: "A partir de R$ 140",
    priceNote: "/ noite · código SRF2026-EC",
  },
  {
    Icon: Waves,
    name: "Praia Palace Hotel",
    dist: "3,0 km · ~8 min de carro",
    featured: false,
    desc: "Para quem deseja unir o simpósio a uma estadia privilegiada à beira-mar, com vistas da Baía de Vitória.",
    amenities: [
      { label: "Vista para o mar", Icon: WavesIcon },
      { label: "Piscina", Icon: WavesLadder },
      { label: "Café da manhã", Icon: Coffee },
    ],
    price: "A partir de R$ 380",
    priceNote: "/ noite",
  },
  {
    Icon: School,
    name: "Alojamento UFES",
    dist: "2,5 km · Translado organizado",
    featured: false,
    desc: "Vagas limitadas para estudantes participantes. Inscrição até 15 de julho via formulário específico.",
    amenities: [
      { label: "Translado incluso", Icon: Forklift },
      { label: "Refeitório", Icon: Utensils },
      { label: "Wi-Fi", Icon: Wifi },
    ],
    price: "R$ 45",
    priceNote: "/ noite · sujeito a disponibilidade",
  },
];

const venue: Venue = {
  locale: "Instituto Federal do Espírito Santo - Campus Serra",
  place: "Av. dos Sabiás",
  number: "330",
  district: "Morada de Laranjeiras3",
  municipality: "Serra",
  state: "ES",
  identification: "29166-630",
  description: "Auditório principal para 250 pessoas, salas de workshop, refeitório, estacionamento e acessibblidade total.",
  amenities: [
    {
    label: "Linhas 860, 831, 830, 874, 501, 516, 852 e 815",
      Icon: Bus
    },
    {
      label: "Estacionamento",
      Icon: Car
    },
    {
      label: "Acessível",
      Icon: PersonStanding
    },
    {
      label: "Wifi gratuito",
      Icon: Wifi
    },
  ],
  url: "https://www.google.com/maps/place/IFES+-+Campus+Serra/@-20.1976491,-40.2202422,17z/data=!3m1!4b1!4m6!3m5!1s0xb81de52407d8d7:0x289693da8d05dd09!8m2!3d-20.1976491!4d-40.2176673!16s%2Fg%2F11gyc3xq80?entry=ttu&g_ep=EgoyMDI2MDQyMi4wIKXMDSoASAFQAw%3D%3D"
}

---

<section id="hospedagem" class="py-20 border-b border-border">
  <div class="max-w-[980px] mx-auto px-[22px]">
    <span class="text-[11px] font-semibold tracking-[.1em] uppercase text-secondary block mb-[10px]">Logística</span>
    <h2 class="font-['DM_Sans'] text-[clamp(2rem,5vw,3.2rem)] font-normal leading-[1.1] tracking-[-.02em] mb-3">
      Hospedagem & Local
    </h2>
    <p class="text-[17px] text-secondary max-w-[560px] leading-[1.65] mb-12">
      Hotéis parceiros com tarifas especiais para participantes do SRF 2026.
    </p>

    <!-- Hotels Grid -->
    <div class="grid sm:grid-cols-2 gap-3 mb-12">
      {hotels.map((h) => (
        <div class={`border rounded-xl p-7 bg-white transition-all duration-200 ${h.featured ? 'border-brand' : 'border-border hover:border-border-hover hover:shadow-[0_4px_20px_rgba(0,0,0,0.06)]'}`}>
          <div class="text-2xl mb-3.5"><h.Icon size={28} /></div>
          <div class="font-['DM_Sans'] text-[1.1rem] font-normal mb-0.5">{h.name}</div>
          <div class="text-[12px] text-brand font-medium mb-2.5">{h.dist}</div>
          <p class="text-[13.5px] text-secondary leading-[1.65] mb-3.5">{h.desc}</p>
          <div class="flex flex-wrap gap-1.5 mb-4">
            {h.amenities.map((a) => (
              <span class="inline-flex items-center gap-1 text-[11px] border border-border rounded-[980px] px-2.5 py-1 bg-surface text-secondary">
                <a.Icon size={12} />{a.label}
              </span>
            ))}
          </div>
          <div class="text-[15px] font-semibold">
            {h.price} <small class="font-normal text-[12px] text-secondary">{h.priceNote}</small>
          </div>
        </div>
      ))}
    </div>

    <!-- Venue Block -->
    <div class="grid md:grid-cols-2 border border-border rounded-xl overflow-hidden">
      <!-- Map placeholder -->
      <div class="bg-surface min-h-[220px] flex items-center justify-center p-6">
        <svg viewBox="0 0 340 220" width="100%" style="max-width:340px;" xmlns="http://www.w3.org/2000/svg">
          <rect width="340" height="220" fill="#f5f5f7"/>
          <line x1="76" y1="0" x2="76" y2="220" stroke="#d2d2d7" stroke-width="1"/>
          <line x1="170" y1="0" x2="170" y2="220" stroke="#d2d2d7" stroke-width="1"/>
          <line x1="264" y1="0" x2="264" y2="220" stroke="#d2d2d7" stroke-width="1"/>
          <line x1="0" y1="74" x2="340" y2="74" stroke="#d2d2d7" stroke-width="1"/>
          <line x1="0" y1="148" x2="340" y2="148" stroke="#d2d2d7" stroke-width="1"/>
          <rect x="85" y="10" width="78" height="58" rx="4" fill="#e5e5ea"/>
          <rect x="180" y="10" width="76" height="58" rx="4" fill="#e5e5ea"/>
          <rect x="85" y="82" width="170" height="58" rx="4" fill="#ddeeff" stroke="#0071e3" stroke-width="1.5"/>
          <text x="170" y="108" text-anchor="middle" font-size="11" font-family="-apple-system,sans-serif" fill="#0071e3" font-weight="600">IFES - Campus Serra</text>
          <text x="170" y="126" text-anchor="middle" font-size="10" font-family="-apple-system,sans-serif" fill="#0071e3">Serra - ES</text>
          <rect x="85" y="158" width="78" height="52" rx="4" fill="#e5e5ea"/>
          <rect x="182" y="158" width="74" height="52" rx="4" fill="#e5e5ea"/>
          <rect x="278" y="82" width="52" height="128" rx="4" fill="#e5e5ea"/>
          <circle cx="170" cy="111" r="20" fill="rgba(0,113,227,0.12)">
            <animate attributeName="r" values="14;24;14" dur="2.2s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="1;0;1" dur="2.2s" repeatCount="indefinite"/>
          </circle>
          <circle cx="170" cy="111" r="6" fill="#0071e3"/>
        </svg>
      </div>

      <!-- Venue Info -->
      <div class="p-9 bg-white">
        <span class="text-[11px] font-semibold tracking-[.1em] uppercase text-secondary block mb-[10px]">Local do Evento</span>
        <div class="font-['DM_Sans'] text-[1.3rem] font-normal mb-1.5">{venue.locale}</div>
        <div class="text-[13px] text-secondary leading-[1.8] mb-4">
          {venue.place}, {venue.number}<br/>{venue.district} · {venue.municipality} – {venue.state} · CEP {venue.identification}
        </div>
        <p class="text-[14px] text-secondary leading-[1.7] mb-5">
          {venue.description}
        </p>
        <div class="flex flex-wrap gap-1.5 mb-5">
          {venue.amenities.map((a) => (
            <span class="text-[11px] border border-border rounded-[980px] px-2.5 py-1 bg-surface text-secondary inline-flex items-center gap-1"><a.Icon size={12} />{a.label}</span>
          ))}
        </div>
        <a href={venue.url} target="_blank" class="inline-flex items-center gap-1.5 rounded-[980px] text-[14px] font-medium px-5 py-2.5 bg-transparent text-brand border border-border hover:border-brand transition-all">
          Ver no Google Maps ↗
        </a>
      </div>
    </div>
  </div>
</section>
