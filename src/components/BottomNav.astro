---
import { Info, Mic, Calendar, Hotel } from "@lucide/astro";

interface NavItem {
  href: string;
  icon: string;
  label: string;
}

const navItems: NavItem[] = [
  { href: "#sobre", icon: "info", label: "Sobre" },
  { href: "#palestrantes", icon: "mic", label: "Palestrantes" },
  { href: "#cronograma", icon: "calendar", label: "Cronograma" },
  { href: "#hospedagem", icon: "hotel", label: "Hospedagem" },
];
---

<nav class="fixed bottom-0 left-0 right-0 z-50 bg-white/92 backdrop-blur-xl border-t border-border md:hidden" aria-label="Navegação mobile">
  <div class="flex flex-row">
    {navItems.map((item) => (
      <a href={item.href} class="flex-1 flex flex-col items-center gap-0.5 py-2.5 px-1 text-[10px] font-medium text-secondary transition-colors duration-200">
        <span class="text-[18px] leading-1">
          {item.icon === "info" && <Info size={18} />}
          {item.icon === "mic" && <Mic size={18} />}
          {item.icon === "calendar" && <Calendar size={18} />}
          {item.icon === "hotel" && <Hotel size={18} />}
        </span>
        {item.label}
      </a>
    ))}
  </div>
</nav>
