      { time: "09:00–10:00", title: "Sessão Solene de Abertura", speaker: "Reitor da UFES · Presidente SBF Regional", tag: "Cerimônia", tagClass: "bg-tag-green-bg text-tag-green-text" },
      { time: "10:00–11:30", title: "Matéria Condensada Quântica e Topologia", speaker: "Profa. Dra. Ana Lúcia Matos — UNICAMP", tag: "Conferência de Abertura", tagClass: "bg-tag-blue-bg text-tag-blue-text" },
      { time: "11:30–13:30", title: "Almoço", speaker: "—", tag: "Pausa", tagClass: "bg-surface text-secondary" },
      { time: "13:30–15:00", title: "Minicurso: Python para Físicos", speaker: "Dr. Marcos Vieira — UFES · Vagas limitadas", tag: "Workshop", tagClass: "bg-tag-purple-bg text-tag-purple-text" },
      { time: "15:00–17:00", title: "Sessão de Pôsteres I — Graduação", speaker: "Todos os participantes inscritos", tag: "Pôsteres", tagClass: "bg-tag-blue-bg text-tag-blue-text" },
      { time: "19:00–21:00", title: "Jantar de Confraternização", speaker: "Restaurante do Centro de Eventos", tag: "Social", tagClass: "bg-surface text-secondary" },
    ],
  },
  {
    date: "Qui 13/08",
    items: [
      { time: "09:00–10:30", title: "Física de Partículas no LHC: Run 4", speaker: "Prof. Dr. Carlos Eduardo Ferreira — UFRJ", tag: "Palestra Plenária", tagClass: "bg-tag-blue-bg text-tag-blue-text" },
      { time: "10:30–11:00", title: "Coffee Break", speaker: "—", tag: "Pausa", tagClass: "bg-surface text-secondary" },
      { time: "11:00–12:30", title: "Simulações Cosmológicas de Grande Escala", speaker: "Dra. Marina Oshiro — INPE", tag: "Palestra Plenária", tagClass: "bg-tag-blue-bg text-tag-blue-text" },
      { time: "12:30–14:00", title: "Almoço", speaker: "—", tag: "Pausa", tagClass: "bg-surface text-secondary" },
