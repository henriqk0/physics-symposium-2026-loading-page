      { time: "16:00–18:00", title: "Sessão de Pôsteres II — Pós-Graduação", speaker: "Todos os participantes inscritos", tag: "Pôsteres", tagClass: "bg-tag-blue-bg text-tag-blue-text" },
      { time: "18:00–19:30", title: "Mesa-Redonda: O Futuro da Física no Brasil", speaker: "Mediação: Prof. Dr. Thiago Neves Lima — IFES", tag: "Mesa-Redonda", tagClass: "bg-tag-yellow-bg text-tag-yellow-text" },
    ],
  },
  {
