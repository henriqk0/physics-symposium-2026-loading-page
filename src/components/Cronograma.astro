    items: [
      { time: "09:00–10:30", title: "Biofísica: Mecânica de Moléculas Únicas", speaker: "Dra. Júlia Santos Pereira — USP", tag: "Palestra Especial", tagClass: "bg-tag-blue-bg text-tag-blue-text" },
