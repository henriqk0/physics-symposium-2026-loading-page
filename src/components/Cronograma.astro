---

<section id="cronograma" class="py-20 border-b border-border">
  <div class="max-w-[980px] mx-auto px-[22px]">
    <span class="text-[11px] font-semibold tracking-[.1em] uppercase text-secondary block mb-[10px]">Programação</span>
    <h2 class="font-['DM_Sans'] text-[clamp(2rem,5vw,3.2rem)] font-normal leading-[1.1] tracking-[-.02em] mb-3">Cronograma</h2>
    <p class="text-[17px] text-secondary max-w-[560px] leading-[1.65] mb-10">
      Três dias de ciência, aprendizado e conexões.
    </p>

    <div class="flex gap-[4px] border border-border rounded-[980px] p-[3px] w-fit mb-5 bg-surface">
      {days.map((day, i) => (
        <button
          data-day={i + 1}
          class="tab-btn text-[13px] font-medium text-secondary px-[18px] py-2 rounded-[980px] transition-all duration-200 hover:bg-white hover:text-primary"
        >
          {day.date}
        </button>
      ))}
    </div>

    {days.map((day, i) => (
      <div class="day-panel hidden" id={`day-${i + 1}`}>
        <div class="border border-border rounded-xl overflow-hidden">
          {day.items.map((item) => (
            <div class="grid md:grid-cols-[96px_1fr] gap-5 p-5 bg-white border-b border-border last:border-b-0 hover:bg-surface transition-colors duration-150">
              <div class="text-[12px] font-medium text-secondary pt-0.5">{item.time}</div>
              <div>
                <div class="text-[15px] font-medium mb-0.5 leading-[1.4]">{item.title}</div>
                <div class="text-[13px] text-secondary mb-2">{item.speaker}</div>
                <span class={`inline-block text-[11px] font-medium px-2.5 py-1 rounded-[980px] ${item.tagClass}`}>{item.tag}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.day-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const dayNum = tab.getAttribute('data-day');

      if (!dayNum) return;

      panels.forEach((p) => p.classList.add('hidden'));

      tabs.forEach((t) => t.classList.remove('bg-white', 'text-primary', 'shadow'));

      tab.classList.add('bg-white', 'text-primary', 'shadow');

      const targetPanel = document.getElementById(`day-${dayNum}`);
      targetPanel?.classList.remove('hidden');
    });
  });

  // Activate first tab
  if (tabs[0]) {
    tabs[0].click();
  }
</script>
