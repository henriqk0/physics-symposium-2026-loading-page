---
import { Mic, ClipboardList, Wrench, MessageCircle } from "@lucide/astro";

interface Feature {
  Icon: typeof Mic;
  title: string;
  desc: string;
}

const features: Feature[] = [
  {
    Icon: Mic,
    title: "Palestras Magistrais",
    desc: "Conferências plenárias com pesquisadores de renome nacional e internacional.",
  },
  {
    Icon: ClipboardList,
    title: "Sessões de Pôsteres",
    desc: "Apresentação de trabalhos originais com premiação nas categorias graduação e pós-graduação.",
  },
  {
    Icon: Wrench,
    title: "Minicursos e Workshops",
    desc: "Atividades práticas com vagas limitadas: ferramentas computacionais e metodologias.",
  },
  {
    Icon: MessageCircle,
    title: "Mesa-Redonda",
    desc: "Debate aberto sobre o futuro da física no Brasil e oportunidades de colaboração.",
  },
];
---

<section id="sobre" class="py-20 border-b border-border">
  <div class="max-w-[980px] mx-auto px-[22px]">
    <div class="mb-[10px]">
      <span class="text-[11px] font-semibold tracking-[.1em] uppercase text-secondary">Sobre o Evento</span>
    </div>
    <h2 class="font-['DM_Sans'] text-[clamp(2rem,5vw,3.2rem)] font-normal leading-[1.1] tracking-[-.02em] mb-3">
      Onde a física<br />encontra pessoas
    </h2>
    <p class="text-[17px] text-secondary max-w-[560px] leading-[1.65] mb-12">
      O Encontro Capixaba de Física é um dos principais encontros científicos do Espírito Santo, realizado anualmente reunindo pesquisadores, estudantes e professores de toda a região.
    </p>

    <div class="grid md:grid-cols-2 gap-12">
      <div class="space-y-4">
        <p class="text-[16px] text-secondary leading-[1.75]">
          A programação abrange física teórica, experimental e computacional, com espaço para apresentação de trabalhos originais, workshops práticos e mesas de debate sobre o futuro da área no Brasil.
        </p>
        <p class="text-[16px] text-secondary leading-[1.75]">
          Realizado no IFES Campus Serra, o evento reúne desde estudantes de graduação até pesquisadores seniores em um ambiente acolhedor e produtivo.
        </p>
      </div>

      <div class="border border-border rounded-xl overflow-hidden grid divide-y divide-border bg-border">
        {features.map((f) => (
          <div class="bg-white p-6 grid grid-cols-[28px_1fr] gap-4 items-start hover:bg-surface transition-colors duration-150">
            <f.Icon size={18} class="flex-shrink-0 mt-0.5" />
            <div>
              <div class="text-[15px] font-semibold mb-0.5">{f.title}</div>
              <div class="text-[13.5px] text-secondary leading-[1.6]">{f.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
