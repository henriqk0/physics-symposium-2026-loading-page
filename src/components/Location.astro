---
---

<section id="local" class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <h2 class="text-slate-900 text-3xl sm:text-4xl font-bold mb-3">Local do Evento</h2>
      <p class="text-slate-500 text-sm">Universidade Federal do Espírito Santo</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <div class="space-y-6">
        <div class="bg-white border border-slate-200 rounded-lg p-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-blue-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-slate-900 font-semibold mb-1">Endereço</h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                Universidade Federal do Espírito Santo<br />
                Campus de Vitória<br />
                Av. Fernando Ferrari, 514<br />
                Cerro, Vitória – ES<br />
                CEP: 29075-910
              </p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-slate-200 rounded-lg p-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-blue-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="text-slate-900 font-semibold mb-1">Data</h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                18 a 20 de junho de 2026
              </p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-slate-200 rounded-lg p-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-blue-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-slate-900 font-semibold mb-1">Horário</h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                Abertura: 08h30<br />
                Evento: 09h00 – 18h00
              </p>
            </div>
          </div>
        </div>

        <a
          href="https://maps.google.com/?q=UFES+Vit%C3%B3ria+ES"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-full font-medium text-sm hover:bg-blue-700 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Ver no Google Maps
        </a>
      </div>

      <div class="rounded-xl overflow-hidden border border-slate-200 shadow-lg">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d31910.48779790858!2d-40.34!3d-20.28!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjDCsDE3JzA4LjAiUyA0MMKwMjAnMDguMCJX!5e0!3m2!1spt-BR!2sbr!4v1600000000000!5m2!1spt-BR!2sbr"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Local do evento UFES"
        ></iframe>
      </div>
    </div>
  </div>
</section>
