---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1635070041078-e363dbe005cb?q=80&w=2000&auto=format&fit=crop')] bg-cover bg-center"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/70"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8">
      <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
      <span class="text-sm font-medium">Inscrições abertas até 15 de maio</span>
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold leading-tight mb-6">
      Simpósio Regional<br />
      <span class="text-blue-400">de Física</span> 2026
    </h1>

    <p class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-8">
      De 18 a 20 de junho de 2026 | Universidade Federal do Espírito Santo | Vitória, ES
    </p>

    <p class="text-base sm:text-lg text-white/60 max-w-xl mx-auto mb-10">
      Junte-se a pesquisadores, estudantes e especialistas para três dias de descobertas,
      debates e networking no coração da física brasileira.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/inscricoes"
        class="bg-blue-600 text-white px-8 py-3 rounded-full font-semibold text-base hover:bg-blue-700 transition-colors w-full sm:w-auto"
      >
        Fazer Inscrição
      </a>
      <a
        href="/cronograma"
        class="bg-white/10 text-white border border-white/30 px-8 py-3 rounded-full font-semibold text-base hover:bg-white/20 transition-colors w-full sm:w-auto"
      >
        Ver Cronograma
      </a>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mt-16 pt-10 border-t border-white/10">
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-bold text-white">300+</div>
        <div class="text-sm text-white/60 mt-1">Participantes esperados</div>
      </div>
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-bold text-white">15</div>
        <div class="text-sm text-white/60 mt-1">Palestrantes confirmados</div>
      </div>
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-bold text-white">3</div>
        <div class="text-sm text-white/60 mt-1">Dias de evento</div>
      </div>
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-bold text-white">40+</div>
        <div class="text-sm text-white/60 mt-1">Trabalho técnico</div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
