---
import { User } from "@lucide/astro";

interface Speaker {
  name: string;
  affil: string;
  topic: string;
  tag: string;
}

const speakers: Speaker[] = [
  {
    name: "Profa. Dra. Ana Lúcia Matos",
    affil: "UNICAMP · Física Teórica",
    topic: "Matéria condensada quântica e transições de fase topológicos em sistemas de baixa dimensão.",
    tag: "Conferência de Abertura",
  },
  {
    name: "Prof. Dr. Carlos Eduardo Ferreira",
    affil: "UFRJ · Física de Altas Energias",
    topic: "Física de partículas no LHC: resultados recentes e perspectivas para o Run 4 do detector ATLAS.",
    tag: "Palestra Plenária",
  },
  {
    name: "Dra. Marina Oshiro",
    affil: "INPE · Astrofísica Computacional",
    topic: "Simulações cosmológicas de grande escala e a formação de estruturas no universo jovem.",
    tag: "Palestra Plenária",
  },
  {
    name: "Prof. Dr. Roberto Almada",
    affil: "UFES · Ótica e Fotônica",
    topic: "Fibras ópticas de cristal fotônico e aplicações em sensoriamento distribuído.",
    tag: "Workshop",
  },
  {
    name: "Dra. Júlia Santos Pereira",
    affil: "USP · Biofísica",
    topic: "Mecânica de moléculas únicas e as fronteiras entre física e biologia molecular.",
    tag: "Palestra Especial",
  },
  {
    name: "Prof. Dr. Thiago Neves Lima",
    affil: "IFES · Ensino de Física",
    topic: "Metodologias ativas e evidências de aprendizagem significativa no ensino de física.",
    tag: "Mesa-Redonda",
  },
];
---

<section id="palestrantes" class="py-20 bg-surface border-b border-border">
  <div class="max-w-[980px] mx-auto px-[22px]">
    <span class="text-[11px] font-semibold tracking-[.1em] uppercase text-secondary block mb-[10px]">Convidados</span>
    <h2 class="font-['DM_Sans'] text-[clamp(2rem,5vw,3.2rem)] font-normal leading-[1.1] tracking-[-.02em] mb-3">
      Palestrantes
    </h2>
    <p class="text-[17px] text-secondary max-w-[560px] leading-[1.65] mb-12">
      Cientistas e pesquisadores de destaque apresentando o estado da arte em diferentes áreas da física.
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-[1px] bg-border border border-border rounded-xl overflow-hidden">
      {speakers.map((s) => (
        <div class="bg-white p-8 hover:bg-surface transition-colors duration-150">
          <div class="w-12 h-12 rounded-full bg-surface border border-border flex items-center justify-center text-[20px] mb-4">
            <User size={20} />
          </div>
          <div class="font-['DM_Sans'] text-[1.05rem] font-normal leading-[1.3] mb-0.5">{s.name}</div>
          <div class="text-[11.5px] text-brand font-medium tracking-[.03em] mb-3">{s.affil}</div>
          <p class="text-[13.5px] text-secondary leading-[1.6] mb-3">{s.topic}</p>
          <span class="inline-block text-[11px] font-medium px-2.5 py-1 rounded-[980px] border border-border text-secondary">
            {s.tag}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
