---
interface Plan {
  name: string;
  for: string;
  price: string;
  unit: string;
  featured: boolean;
  badge?: string;
  features: string[];
}

const plans: Plan[] = [
  {
    name: "Estudante de Graduação",
    for: "Com comprovante de matrícula vigente",
    price: "R$ 80",
    unit: "/ pessoa",
    featured: false,
    features: [
      "Acesso a todas as palestras e plenárias",
      "Participação em sessões de pôsteres",
      "Material do evento e certificado",
      "Coffee breaks incluídos",
    ],
  },
  {
    name: "Pós-Graduação / Pesquisador",
    for: "Mestrandos, doutorandos e pesquisadores",
    price: "R$ 180",
    unit: "/ pessoa",
    featured: true,
    badge: "Mais popular",
    features: [
      "Acesso completo ao evento",
      "Inscrição de trabalho (pôster ou oral)",
      "Publicação nos anais do evento",
      "Coffee breaks e jantar de confraternização",
      "Acesso aos workshops",
    ],
  },
  {
    name: "Professor / Profissional",
    for: "Docentes da educação básica e superior",
    price: "R$ 220",
    unit: "/ pessoa",
    featured: false,
    features: [
      "Acesso completo ao evento",
      "Certificado com carga horária detalhada",
      "Networking acadêmico exclusivo",
      "Coffee breaks e jantar de confraternização",
    ],
  },
];

const categories: string[] = [
  "Estudante de Graduação",
  "Mestrando / Doutorando",
  "Pesquisador / Docente",
  "Professor da Ed. Básica",
  "Profissional",
];

const areas: string[] = [
  "Física Teórica",
  "Física Experimental",
  "Física Computacional",
  "Astrofísica / Cosmologia",
  "Matéria Condensada",
  "Biofísica",
  "Ótica e Fotônica",
  "Ensino de Física",
];
---

<section id="inscricao" class="py-20 bg-surface border-b border-border">
  <div class="max-w-[980px] mx-auto px-[22px]">
    <span class="text-[11px] font-semibold tracking-[.1em] uppercase text-secondary block mb-[10px]">Participação</span>
    <h2 class="font-['DM_Sans'] text-[clamp(2rem,5vw,3.2rem)] font-normal leading-[1.1] tracking-[-.02em] mb-3">
      Inscrição
    </h2>
    <p class="text-[17px] text-secondary max-w-[560px] leading-[1.65] mb-12">
      Vagas limitadas. Inscrições encerram em 31 de julho de 2026.
    </p>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- Plans -->
      <div class="space-y-3">
        {plans.map((plan) => (
          <div class={`relative border rounded-xl p-6 bg-white transition-colors duration-200 ${plan.featured ? 'border-brand bg-surface-brand' : 'border-border hover:border-border-hover'}`}>
            {plan.badge && (
              <span class="absolute -top-2.5 left-5 bg-brand text-white text-[10px] font-semibold tracking-[.08em] px-2.5 py-0.5 rounded-[980px]">
                {plan.badge}
              </span>
            )}
            <div class="text-[15px] font-semibold mb-0.5">{plan.name}</div>
            <div class="text-[12px] text-secondary mb-3.5">{plan.for}</div>
            <div class="font-['DM_Sans'] text-2xl leading-none mb-3.5">
              {plan.price} <small class="text-[13px] text-secondary font-family-sans">{plan.unit}</small>
            </div>
            <ul class="space-y-1.5">
              {plan.features.map((f) => (
                <li class="text-[13px] text-secondary flex gap-2 items-baseline">
                  <span class="text-brand font-bold flex-shrink-0">·</span>{f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Form -->
      <div class="bg-surface border border-border rounded-xl p-8">
        <div id="form-main">
          <div class="font-['DM_Sans'] text-[1.5rem] font-normal mb-1.5">Formulário de Inscrição</div>
          <p class="text-[14px] text-secondary mb-6">Preencha os dados para garantir sua vaga.</p>

          <div class="mb-4">
            <label class="block text-[12px] font-semibold tracking-[.05em] text-secondary mb-1.5">Nome completo *</label>
            <input type="text" id="f-nome" class="w-full bg-white border border-border rounded-lg px-4 py-2.5 text-[15px] text-primary outline-none focus:border-brand focus:shadow-[0_0_0_3px_rgba(0,113,227,0.12)] transition-all placeholder:text-placeholder" placeholder="Seu nome completo" />
          </div>

          <div class="grid grid-cols-2 gap-3 mb-4">
            <div>
              <label class="block text-[12px] font-semibold tracking-[.05em] text-secondary mb-1.5">E-mail *</label>
              <input type="email" id="f-email" class="w-full bg-white border border-border rounded-lg px-4 py-2.5 text-[15px] text-primary outline-none focus:border-brand focus:shadow-[0_0_0_3px_rgba(0,113,227,0.12)] transition-all placeholder:text-placeholder" placeholder="seu@email.com" />
            </div>
            <div>
              <label class="block text-[12px] font-semibold tracking-[.05em] text-secondary mb-1.5">Telefone</label>
              <input type="tel" class="w-full bg-white border border-border rounded-lg px-4 py-2.5 text-[15px] text-primary outline-none focus:border-brand focus:shadow-[0_0_0_3px_rgba(0,113,227,0.12)] transition-all placeholder:text-placeholder" placeholder="(27) 9 9000-0000" />
            </div>
          </div>

          <div class="mb-4">
            <label class="block text-[12px] font-semibold tracking-[.05em] text-secondary mb-1.5">Instituição *</label>
            <input type="text" id="f-inst" class="w-full bg-white border border-border rounded-lg px-4 py-2.5 text-[15px] text-primary outline-none focus:border-brand focus:shadow-[0_0_0_3px_rgba(0,113,227,0.12)] transition-all placeholder:text-placeholder" placeholder="Ex: UFES, IFES, USP…" />
          </div>

          <div class="grid grid-cols-2 gap-3 mb-4">
            <div>
              <label class="block text-[12px] font-semibold tracking-[.05em] text-secondary mb-1.5">Categoria *</label>
              <select id="f-cat" class="w-full bg-white border border-border rounded-lg px-4 py-2.5 text-[15px] text-primary outline-none focus:border-brand focus:shadow-[0_0_0_3px_rgba(0,113,227,0.12)] transition-all appearance-none">
                <option value="">Selecione…</option>
                {categories.map((c) => <option value={c}>{c}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-[12px] font-semibold tracking-[.05em] text-secondary mb-1.5">Área de interesse</label>
              <select class="w-full bg-white border border-border rounded-lg px-4 py-2.5 text-[15px] text-primary outline-none focus:border-brand focus:shadow-[0_0_0_3px_rgba(0,113,227,0.12)] transition-all appearance-none">
                <option value="">Selecione…</option>
                {areas.map((a) => <option value={a}>{a}</option>)}
              </select>
            </div>
          </div>

          <div class="mb-4">
            <label class="block text-[12px] font-semibold tracking-[.05em] text-secondary mb-1.5">Submissão de trabalho</label>
            <select class="w-full bg-white border border-border rounded-lg px-4 py-2.5 text-[15px] text-primary outline-none focus:border-brand focus:shadow-[0_0_0_3px_rgba(0,113,227,0.12)] transition-all appearance-none">
              <option>Não — apenas participação</option>
              <option>Sim — Pôster</option>
              <option>Sim — Comunicação Oral</option>
            </select>
          </div>

          <div class="mb-5">
            <label class="block text-[12px] font-semibold tracking-[.05em] text-secondary mb-1.5">Observações / Acessibilidade</label>
            <textarea class="w-full bg-white border border-border rounded-lg px-4 py-2.5 text-[15px] text-primary outline-none focus:border-brand focus:shadow-[0_0_0_3px_rgba(0,113,227,0.12)] transition-all resize-none min-h-[90px] leading-relaxed placeholder:text-placeholder" placeholder="Necessidades especiais ou observações…"></textarea>
          </div>

          <button id="btn-submit" class="w-full bg-brand text-white border-none rounded-[980px] px-6 py-3 text-[15px] font-medium cursor-pointer hover:bg-brand-hover hover:shadow-[0_2px_14px_rgba(0,113,227,0.25)] transition-all">
            Confirmar inscrição
          </button>
          <p class="text-[12px] text-secondary text-center mt-3 leading-relaxed">
            Você receberá um e-mail com instruções de pagamento e confirmação da vaga.
          </p>
        </div>

        <div id="form-success" class="hidden text-center py-12">
          <div class="text-4xl mb-4">✅</div>
          <div class="font-['DM_Sans'] text-[1.6rem] font-normal mb-2.5">Inscrição recebida!</div>
          <p class="text-[15px] text-secondary leading-[1.7]">
            Obrigado pela inscrição no SRF 2026.<br>Enviamos as instruções de pagamento para o seu e-mail.<br>Nos vemos em Vitória em agosto.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('btn-submit')?.addEventListener('click', () => {
    const nome  = (document.getElementById('f-nome') as HTMLInputElement)?.value.trim();
    const email = (document.getElementById('f-email') as HTMLInputElement)?.value.trim();
    const inst  = (document.getElementById('f-inst') as HTMLInputElement)?.value.trim();
    const cat   = (document.getElementById('f-cat') as HTMLSelectElement)?.value;
    if (!nome || !email || !inst || !cat) {
      alert('Por favor, preencha os campos obrigatórios (*).');
      return;
    }
    document.getElementById('form-main')!.style.display = 'none';
    document.getElementById('form-success')!.classList.remove('hidden');
  });
</script>
