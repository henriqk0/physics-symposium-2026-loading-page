---
const footerLinks = {
  evento: [
    { label: "Sobre o SRFES", href: "/#sobre" },
    { label: "Cronograma", href: "/cronograma" },
    { label: "Palestrantes", href: "/palestrantes" },
    { label: "Local", href: "/#local" },
  ],
  inscricao: [
    { label: "Inscrições", href: "/inscricoes" },
    { label: "Valores", href: "/inscricoes#valores" },
    { label: "Formas de Pagamento", href: "/inscricoes#pagamento" },
    { label: "Política de Cancelamento", href: "/inscricoes#cancelamento" },
  ],
  recursos: [
    { label: "Submissão de Trabalhos", href: "/submissoes" },
    { label: "Certificados", href: "/certificados" },
    { label: "Normas para Pôsteres", href: "/normas" },
    { label: "Programa de Voluntários", href: "/voluntarios" },
  ],
  contato: [
    { label: "Fale Conosco", href: "mailto:srfes2026@ifes.edu.br" },
    { label: "Comitê Organizador", href: "/comite" },
    { label: "Assessoria de Imprensa", href: "mailto:imprensa@ifes.edu.br" },
  ],
};

const socialLinks = [
  { label: "Instagram", href: "https://instagram.com/srfes2026", icon: "instagram" },
  { label: "Twitter/X", href: "https://twitter.com/srfes2026", icon: "twitter" },
  { label: "YouTube", href: "https://youtube.com/@srfes2026", icon: "youtube" },
  { label: "LinkedIn", href: "https://linkedin.com/company/srfes2026", icon: "linkedin" },
];
---

<footer class="bg-slate-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-10">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center">
            <span class="text-white font-bold text-sm">SRF</span>
          </div>
          <div>
            <span class="font-semibold text-white text-sm">Simpósio Regional de Física</span>
            <span class="text-blue-400 text-xs block">SRFES 2026</span>
          </div>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed mb-6">
          O Simpósio Regional de Física do Espírito Santo é um evento científico realizado pelo Instituto Federal do Espírito Santo em parceria com a UFES e a Sociedade Brasileira de Física.
        </p>
        <div class="flex gap-3">
          <a href="https://instagram.com/srfes2026" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-slate-800 flex items-center justify-center hover:bg-blue-600 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://twitter.com/srfes2026" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-slate-800 flex items-center justify-center hover:bg-blue-600 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://youtube.com/@srfes2026" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-slate-800 flex items-center justify-center hover:bg-blue-600 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a href="https://linkedin.com/company/srfes2026" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-slate-800 flex items-center justify-center hover:bg-blue-600 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Evento</h3>
        <ul class="space-y-2.5">
          {footerLinks.evento.map((link) => (
            <li>
              <a href={link.href} class="text-slate-400 text-sm hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Inscrição</h3>
        <ul class="space-y-2.5">
          {footerLinks.inscricao.map((link) => (
            <li>
              <a href={link.href} class="text-slate-400 text-sm hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Contato</h3>
        <ul class="space-y-2.5">
          {footerLinks.contato.map((link) => (
            <li>
              <a href={link.href} class="text-slate-400 text-sm hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-slate-500 text-xs">
          © 2026 SRFES – Simpósio Regional de Física do Espírito Santo. Todos os direitos reservados.
        </p>
        <div class="flex items-center gap-2">
          <span class="text-slate-600 text-xs">Realização:</span>
          <div class="flex items-center gap-2">
            <span class="text-slate-400 text-xs font-medium">IFES</span>
            <span class="text-slate-600">•</span>
            <span class="text-slate-400 text-xs font-medium">UFES</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
