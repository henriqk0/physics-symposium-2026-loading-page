---
const footerLinks = ["Sobre", "Palestrantes", "Cronograma", "Inscrição", "Hospedagem"] as const;
---

<footer class="bg-surface border-t border-border py-14 px-[22px]">
  <div class="max-w-[980px] mx-auto">
    <div class="grid md:grid-cols-[2fr_1fr_1fr] gap-9 mb-12">
      <div>
        <div class="text-[14px] font-semibold mb-2.5">SRF 2026 — Simpósio Regional de Física</div>
        <p class="text-[13px] text-secondary leading-[1.65]">
          Organizado pela Sociedade Brasileira de Física, Regional Sudeste, em parceria com a UFES e o IFES.
        </p>
      </div>
      <div>
        <h4 class="text-[12px] font-semibold tracking-[.05em] uppercase text-secondary mb-3.5">Evento</h4>
        <ul class="space-y-2">
          {footerLinks.map((link) => (
            <li>
              <a href={`#${link.toLowerCase()}`} class="text-[13px] text-secondary hover:text-primary transition-colors duration-200">
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-[12px] font-semibold tracking-[.05em] uppercase text-secondary mb-3.5">Contato</h4>
        <ul class="space-y-2">
          <li><a href="mailto:srf2026@ufes.br" class="text-[13px] text-secondary hover:text-primary transition-colors duration-200">srf2026@ufes.br</a></li>
          <li><a href="tel:+552733359400" class="text-[13px] text-secondary hover:text-primary transition-colors duration-200">(27) 3335-9400</a></li>
          <li><a href="#" class="text-[13px] text-secondary hover:text-primary transition-colors duration-200">Submissão de trabalhos</a></li>
          <li><a href="#" class="text-[13px] text-secondary hover:text-primary transition-colors duration-200">Patrocínio</a></li>
        </ul>
      </div>
    </div>
    <div class="flex flex-wrap gap-3 justify-between pt-6 border-t border-border text-[12px] text-secondary">
      <span>© 2026 SRF — Todos os direitos reservados.</span>
      <span>SBF Regional Sudeste · UFES · IFES</span>
    </div>
  </div>
</footer>
