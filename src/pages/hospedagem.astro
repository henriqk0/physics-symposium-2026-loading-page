---
import Layout from "../layouts/Layout.astro";
import SponsorsSection from "../components/SponsorsSection.astro";
import SponsorsBar from "../components/SponsorsBar.astro";

const hotels = [
  {
    name: "Hotel Quality",
    stars: 4,
    distance: "3 km do evento",
    priceRange: "R$ 180 - 280",
    features: ["Café da manhã incluso", "Wi-Fi gratuito", "Academia", "Estacionamento"],
    discount: "10% para participantes",
    link: "https://wwwBooking.com",
    phone: "(27) 3335-1234",
  },
  {
    name: "Hotel Ibis Vit.",
    stars: 3,
    distance: "5 km do evento",
    priceRange: "R$ 120 - 180",
    features: ["Wi-Fi gratuito", "Restaurant", "Bar", "Acessibilidade"],
    discount: "Código: SRFES2026",
    link: "https://wwwBooking.com",
    phone: "(27) 3335-5678",
  },
  {
    name: "Hotel Senac",
    stars: 3,
    distance: "2 km do evento",
    priceRange: "R$ 150 - 220",
    features: ["Café da manhã incluso", "Wi-Fi gratuito", "Sala de eventos", "Estacionamento"],
    discount: "15% para grupos",
    link: "https://wwwBooking.com",
    phone: "(27) 3335-9012",
  },
  {
    name: "Slaviero Vit.",
    stars: 4,
    distance: "4 km do evento",
    priceRange: "R$ 200 - 300",
    features: ["Café da manhã incluso", "Wi-Fi gratuito", "Piscina", "SPA", "Academia"],
    discount: "20% finais de semana",
    link: "https://wwwBooking.com",
    phone: "(27) 3335-3456",
  },
  {
    name: "Hotel Premier",
    stars: 3,
    distance: "6 km do evento",
    priceRange: "R$ 100 - 160",
    features: ["Wi-Fi gratuito", "Café da manhã", "Estacionamento gratuito"],
    discount: "5% com código SRFES",
    link: "https://wwwBooking.com",
    phone: "(27) 3335-7890",
  },
  {
    name: "Hotel Europa",
    stars: 2,
    distance: "1 km do evento",
    priceRange: "R$ 80 - 120",
    features: ["Wi-Fi gratuito", "Café simples", "Localização central"],
    discount: "Taxa reduz. em grupo",
    link: "https://wwwBooking.com",
    phone: "(27) 3335-2345",
  },
];
---

<Layout title="Hospedagem – SRFES 2026">
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <h1 class="text-slate-900 text-3xl font-bold mb-3">Hospedagem</h1>
        <p class="text-slate-600 max-w-2xl">
          Opções de hospedagem próximas ao local do evento.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {hotels.map((hotel) => (
          <div class="bg-white border border-slate-200 rounded-xl p-6 hover:shadow-lg hover:border-slate-300 transition-all">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-slate-900 font-semibold">{hotel.name}</h3>
              <div class="flex gap-0.5">
                {Array.from({ length: hotel.stars }).map(() => (
                  <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>

            <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {hotel.distance}
            </div>

            <div class="mb-4">
              <p class="text-slate-900 font-semibold">{hotel.priceRange}</p>
              <p class="text-blue-600 text-xs">{hotel.discount}</p>
            </div>

            <ul class="space-y-1.5 mb-5">
              {hotel.features.map((feature) => (
                <li class="flex items-center gap-2 text-slate-600 text-xs">
                  <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <div class="flex flex-col gap-2">
              <a
                href={hotel.link}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full text-center bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors"
              >
                Reservar
              </a>
              <a
                href={`tel:${hotel.phone.replace(/\D/g, "")}`}
                class="w-full text-center bg-slate-100 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-200 transition-colors"
              >
                {hotel.phone}
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-xl p-6">
        <h3 class="text-slate-900 font-semibold mb-3">Dicas de Hospedagem</h3>
        <ul class="space-y-2 text-slate-600 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Os hotéis indicados ficam a até 6 km do Campus de Vitória da UFES
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Reserve com antecedência — junho é época de alta temporada em Vitória
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Há opções de transporte coletivo (ônibus) entre os hotéis e a UFES
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Para grupos, entre em contato diretamente com os hotéis para negociar tarifas
          </li>
        </ul>
      </div>
    </div>
  </section>
  <SponsorsSection />
</Layout>
